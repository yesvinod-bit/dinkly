rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isRegisteredUser() {
      return isSignedIn() &&
             (!request.auth.token.firebase.keys().hasAny(['sign_in_provider']) ||
              request.auth.token.firebase.sign_in_provider != 'anonymous');
    }

    function isOwner(tournamentId) {
      return isRegisteredUser() && get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return isRegisteredUser() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == 'yes.vinod@gmail.com';
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function tournamentPath(tournamentId) {
      return /databases/$(database)/documents/tournaments/$(tournamentId);
    }

    function tournamentDoc(tournamentId) {
      return get(tournamentPath(tournamentId)).data;
    }

    function tournamentExists(tournamentId) {
      return exists(tournamentPath(tournamentId));
    }

    function tournamentStatus(tournamentId) {
      return tournamentDoc(tournamentId).status;
    }

    function tournamentMemberPath(tournamentId) {
      return /databases/$(database)/documents/users/$(request.auth.uid)/tournaments/$(tournamentId);
    }

    function isTournamentMember(tournamentId) {
      return isRegisteredUser() && exists(tournamentMemberPath(tournamentId));
    }

    function tournamentFormat(tournamentId) {
      return tournamentExists(tournamentId) && tournamentDoc(tournamentId).format == 'singles'
        ? 'singles'
        : 'doubles';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /tournaments/{tournamentId} {
      function isValidTournamentDocument(data) {
        return data.keys().hasAll(['name', 'code', 'ownerId', 'status', 'createdAt']) &&
               data.keys().hasOnly(['name', 'code', 'ownerId', 'format', 'pairingMode', 'status', 'createdAt', 'updatedAt']) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.code is string && data.code.matches('^[A-Z0-9]{6}$') &&
               data.ownerId == request.auth.uid &&
               (!data.keys().hasAny(['format']) || data.format in ['singles', 'doubles']) &&
               (!data.keys().hasAny(['pairingMode']) || data.pairingMode in ['random', 'fixed']) &&
               data.status in ['setup', 'active', 'completed'] &&
               data.createdAt is timestamp &&
               (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp);
      }

      function isValidTournamentStatusTransition(before, after) {
        return before == after ||
               (before == 'setup' && after == 'active') ||
               (before == 'active' && after == 'completed');
      }

      function hasSamePairingMode(before, after) {
        return (!before.keys().hasAny(['pairingMode']) && !after.keys().hasAny(['pairingMode'])) ||
               (before.keys().hasAny(['pairingMode']) &&
                after.keys().hasAny(['pairingMode']) &&
                before.pairingMode == after.pairingMode);
      }

      allow get: if true;
      allow list: if isRegisteredUser(); // Queries by code or ownerId

      allow create: if isValidId(tournamentId) &&
                    isRegisteredUser() &&
                    isValidTournamentDocument(incoming()) &&
                    incoming().status == 'setup';
      
      allow update: if isValidId(tournamentId) &&
                    tournamentExists(tournamentId) &&
                    isOwner(tournamentId) &&
                    isValidTournamentDocument(incoming()) && 
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().code == existing().code &&
                    incoming().format == existing().format &&
                    (existing().status == 'setup' || hasSamePairingMode(existing(), incoming())) &&
                    isValidTournamentStatusTransition(existing().status, incoming().status) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'pairingMode', 'status', 'updatedAt']);

      // Players Subcollection
      match /players/{playerId} {
        function hasClaimedByUserId(data) {
          return data.keys().hasAny(['claimedByUserId']);
        }

        function hasClaimedByEmail(data) {
          return data.keys().hasAny(['claimedByEmail']);
        }

        function hasClaimedAt(data) {
          return data.keys().hasAny(['claimedAt']);
        }

        function hasValidClaimFields(data) {
          return (!hasClaimedByUserId(data) &&
                  !hasClaimedByEmail(data) &&
                  !hasClaimedAt(data)) ||
                 (hasClaimedByUserId(data) &&
                  hasClaimedByEmail(data) &&
                  hasClaimedAt(data) &&
                  data.claimedByUserId is string &&
                  data.claimedByEmail is string &&
                  data.claimedAt is timestamp);
        }

        function isValidPlayerDocument(data) {
          return data.keys().hasAll(['name', 'points', 'gamesPlayed', 'wins', 'addedAt']) &&
                 data.keys().hasOnly(['name', 'points', 'gamesPlayed', 'wins', 'addedAt', 'fixedPairId', 'claimedByUserId', 'claimedByEmail', 'claimedAt']) &&
                 data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
                 data.points is number &&
                 data.gamesPlayed is number && data.gamesPlayed >= 0 &&
                 data.wins is number && data.wins >= 0 && data.wins <= data.gamesPlayed &&
                 data.addedAt is timestamp &&
                 (!data.keys().hasAny(['fixedPairId']) ||
                  (data.fixedPairId is string && data.fixedPairId.size() > 0 && data.fixedPairId.size() <= 80)) &&
                 hasValidClaimFields(data);
        }

        allow read: if true;
        allow create: if isValidId(tournamentId) &&
                      isValidId(playerId) &&
                      tournamentExists(tournamentId) &&
                      isTournamentMember(tournamentId) &&
                      tournamentStatus(tournamentId) == 'setup' &&
                      isValidPlayerDocument(incoming()) &&
                      incoming().points == 0 &&
                      incoming().gamesPlayed == 0 &&
                      incoming().wins == 0 &&
                      (
                        !hasClaimedByUserId(incoming()) ||
                        (
                          incoming().claimedByUserId == request.auth.uid &&
                          incoming().claimedByEmail == request.auth.token.email
                        )
                      );
        allow delete: if isValidId(tournamentId) &&
                      isValidId(playerId) &&
                      tournamentExists(tournamentId) &&
                      isOwner(tournamentId) &&
                      tournamentStatus(tournamentId) == 'setup';
        allow update: if isValidId(tournamentId) &&
                      isValidId(playerId) &&
                      tournamentExists(tournamentId) &&
                      tournamentStatus(tournamentId) in ['setup', 'active', 'completed'] &&
                      isTournamentMember(tournamentId) &&
                      isValidPlayerDocument(incoming()) &&
                      existing().name == incoming().name &&
                      existing().points == incoming().points &&
                      existing().gamesPlayed == incoming().gamesPlayed &&
                      existing().wins == incoming().wins &&
                      existing().addedAt == incoming().addedAt &&
                      !hasClaimedByUserId(existing()) &&
                      incoming().claimedByUserId == request.auth.uid &&
                      incoming().claimedByEmail == request.auth.token.email &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['claimedByUserId', 'claimedByEmail', 'claimedAt']);
        allow update: if isValidId(tournamentId) &&
                      isValidId(playerId) &&
                      tournamentExists(tournamentId) &&
                      isOwner(tournamentId) &&
                      tournamentStatus(tournamentId) == 'setup' &&
                      isValidPlayerDocument(incoming()) &&
                      existing().name == incoming().name &&
                      existing().points == incoming().points &&
                      existing().gamesPlayed == incoming().gamesPlayed &&
                      existing().wins == incoming().wins &&
                      existing().addedAt == incoming().addedAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['fixedPairId']);
        allow update: if isValidId(tournamentId) &&
                      isValidId(playerId) &&
                      tournamentExists(tournamentId) &&
                      isOwner(tournamentId) &&
                      tournamentStatus(tournamentId) in ['active', 'completed'];
      }

      // Matches Subcollection
      match /matches/{matchId} {
        function hasUniqueTeamMembers(team) {
          return team.size() == 1 || team[0] != team[1];
        }

        function hasCompletedAtField(data) {
          return data.keys().hasAny(['completedAt']);
        }

        function hasVoidedAtField(data) {
          return data.keys().hasAny(['voidedAt']);
        }

        function hasStatusBeforeVoidField(data) {
          return data.keys().hasAny(['statusBeforeVoid']);
        }

        function hasPreviousScore1Field(data) {
          return data.keys().hasAny(['previousScore1']);
        }

        function hasPreviousScore2Field(data) {
          return data.keys().hasAny(['previousScore2']);
        }

        function hasPreviousCompletedAtField(data) {
          return data.keys().hasAny(['previousCompletedAt']);
        }

        function hasStageField(data) {
          return data.keys().hasAny(['stage']);
        }

        function hasPlayoffRoundField(data) {
          return data.keys().hasAny(['playoffRound']);
        }

        function hasRoundLabelField(data) {
          return data.keys().hasAny(['roundLabel']);
        }

        function hasSeed1Field(data) {
          return data.keys().hasAny(['seed1']);
        }

        function hasSeed2Field(data) {
          return data.keys().hasAny(['seed2']);
        }

        function isValidTeam(team) {
          return team is list &&
                 team.size() == (tournamentFormat(tournamentId) == 'singles' ? 1 : 2) &&
                 hasUniqueTeamMembers(team);
        }

        function isValidCompletedAt(data) {
          return !hasCompletedAtField(data) || data.completedAt == null || data.completedAt is timestamp;
        }

        function isValidVoidedAt(data) {
          return !hasVoidedAtField(data) || data.voidedAt == null || data.voidedAt is timestamp;
        }

        function isValidStatusBeforeVoid(data) {
          return !hasStatusBeforeVoidField(data) ||
                 data.statusBeforeVoid == null ||
                 data.statusBeforeVoid in ['pending', 'completed'];
        }

        function isValidPreviousScore1(data) {
          return !hasPreviousScore1Field(data) ||
                 data.previousScore1 == null ||
                 (data.previousScore1 is number && data.previousScore1 >= 0);
        }

        function isValidPreviousScore2(data) {
          return !hasPreviousScore2Field(data) ||
                 data.previousScore2 == null ||
                 (data.previousScore2 is number && data.previousScore2 >= 0);
        }

        function isValidPreviousCompletedAt(data) {
          return !hasPreviousCompletedAtField(data) ||
                 data.previousCompletedAt == null ||
                 data.previousCompletedAt is timestamp;
        }

        function isValidStage(data) {
          return !hasStageField(data) ||
                 data.stage in ['preliminary', 'playoff'];
        }

        function isValidPlayoffRound(data) {
          return !hasPlayoffRoundField(data) ||
                 (data.playoffRound is number && data.playoffRound >= 1);
        }

        function isValidRoundLabel(data) {
          return !hasRoundLabelField(data) ||
                 (data.roundLabel is string && data.roundLabel.size() > 0 && data.roundLabel.size() <= 80);
        }

        function isValidSeeds(data) {
          return (!hasSeed1Field(data) || (data.seed1 is number && data.seed1 >= 1)) &&
                 (!hasSeed2Field(data) || (data.seed2 is number && data.seed2 >= 1));
        }

        function isValidScoresForStatus(data) {
          return (data.status == 'pending' &&
                  data.score1 == 0 &&
                  data.score2 == 0 &&
                  (!hasCompletedAtField(data) || data.completedAt == null)) ||
                 (data.status == 'void' &&
                  data.score1 == 0 &&
                  data.score2 == 0 &&
                  (!hasCompletedAtField(data) || data.completedAt == null)) ||
                 (data.status == 'completed' &&
                  data.score1 is number && data.score1 >= 0 &&
                  data.score2 is number && data.score2 >= 0 &&
                  data.score1 != data.score2 &&
                  hasCompletedAtField(data) &&
                  data.completedAt is timestamp);
        }

        function isValidMatchDocument(data) {
          return data.keys().hasAll(['round', 'team1', 'team2', 'score1', 'score2', 'status', 'updatedAt']) &&
                 data.keys().hasOnly([
                   'round',
                   'team1',
                   'team2',
                   'score1',
                   'score2',
                   'status',
                   'updatedAt',
                   'completedAt',
                   'voidedAt',
                   'statusBeforeVoid',
                   'previousScore1',
                   'previousScore2',
                   'previousCompletedAt',
                   'stage',
                   'playoffRound',
                   'roundLabel',
                   'seed1',
                   'seed2'
                 ]) &&
                 data.round is number && data.round >= 1 &&
                 isValidTeam(data.team1) &&
                 isValidTeam(data.team2) &&
                 !data.team1.hasAny(data.team2) &&
                 data.status in ['pending', 'completed', 'void'] &&
                 isValidCompletedAt(data) &&
                 isValidVoidedAt(data) &&
                 isValidStatusBeforeVoid(data) &&
                 isValidPreviousScore1(data) &&
                 isValidPreviousScore2(data) &&
                 isValidPreviousCompletedAt(data) &&
                 isValidStage(data) &&
                 isValidPlayoffRound(data) &&
                 isValidRoundLabel(data) &&
                 isValidSeeds(data) &&
                 isValidScoresForStatus(data) &&
                 data.updatedAt is timestamp;
        }

        function isParticipantScoreUpdate() {
          return tournamentStatus(tournamentId) == 'active' &&
                 isTournamentMember(tournamentId) &&
                 isValidMatchDocument(incoming()) &&
                 existing().status in ['pending', 'completed'] &&
                 incoming().status == 'completed' &&
                 incoming().diff(existing()).affectedKeys().hasOnly(['score1', 'score2', 'status', 'updatedAt', 'completedAt']);
        }

        allow read: if true;
        allow create: if isValidId(tournamentId) &&
                      isValidId(matchId) &&
                      tournamentExists(tournamentId) &&
                      isOwner(tournamentId) &&
                      tournamentStatus(tournamentId) == 'active';
        allow update: if isValidId(tournamentId) &&
                      isValidId(matchId) &&
                      tournamentExists(tournamentId) &&
                      isOwner(tournamentId);
        allow update: if isValidId(tournamentId) &&
                      isValidId(matchId) &&
                      tournamentExists(tournamentId) &&
                      isParticipantScoreUpdate();
      }

      match /sessions/{sessionId} {
        allow read: if true;
        allow create: if isValidId(tournamentId) &&
                      isValidId(sessionId) &&
                      tournamentExists(tournamentId) &&
                      isOwner(tournamentId) &&
                      incoming().keys().hasAll(['name', 'startRound', 'status', 'absences', 'createdAt']) &&
                      incoming().name is string &&
                      incoming().name.size() > 0 &&
                      incoming().name.size() <= 100 &&
                      incoming().startRound is number &&
                      incoming().startRound >= 1 &&
                      incoming().status in ['active', 'completed'] &&
                      incoming().absences is map &&
                      incoming().createdAt is timestamp;
        allow update: if isValidId(tournamentId) &&
                      isValidId(sessionId) &&
                      tournamentExists(tournamentId) &&
                      isOwner(tournamentId);
      }

      match /scoreNotifications/{notificationId} {
        function isValidScoreNotification(data) {
          return data.keys().hasAll([
                   'matchId',
                   'tournamentName',
                   'round',
                   'roundLabel',
                   'team1Label',
                   'team2Label',
                   'score1',
                   'score2',
                   'previousScore1',
                   'previousScore2',
                   'action',
                   'actorUserId',
                   'actorDisplayName',
                   'recipientUserIds',
                   'createdAt'
                 ]) &&
                 data.keys().hasOnly([
                   'matchId',
                   'tournamentName',
                   'round',
                   'roundLabel',
                   'team1Label',
                   'team2Label',
                   'score1',
                   'score2',
                   'previousScore1',
                   'previousScore2',
                   'action',
                   'actorUserId',
                   'actorDisplayName',
                   'recipientUserIds',
                   'createdAt'
                 ]) &&
                 data.matchId is string &&
                 data.matchId.size() > 0 &&
                 data.matchId.size() <= 128 &&
                 data.tournamentName is string &&
                 data.tournamentName.size() <= 100 &&
                 data.round is number &&
                 data.round >= 1 &&
                 data.roundLabel is string &&
                 data.roundLabel.size() > 0 &&
                 data.roundLabel.size() <= 80 &&
                 data.team1Label is string &&
                 data.team1Label.size() > 0 &&
                 data.team1Label.size() <= 160 &&
                 data.team2Label is string &&
                 data.team2Label.size() > 0 &&
                 data.team2Label.size() <= 160 &&
                 data.score1 is number &&
                 data.score1 >= 0 &&
                 data.score2 is number &&
                 data.score2 >= 0 &&
                 data.score1 != data.score2 &&
                 (data.previousScore1 == null || (data.previousScore1 is number && data.previousScore1 >= 0)) &&
                 (data.previousScore2 == null || (data.previousScore2 is number && data.previousScore2 >= 0)) &&
                 data.action in ['entered', 'modified'] &&
                 (data.actorUserId == null || data.actorUserId == request.auth.uid) &&
                 data.actorDisplayName is string &&
                 data.actorDisplayName.size() > 0 &&
                 data.actorDisplayName.size() <= 120 &&
                 data.recipientUserIds is list &&
                 data.recipientUserIds.size() > 0 &&
                 data.recipientUserIds.size() <= 80 &&
                 data.createdAt is timestamp;
        }

        allow get, list: if isRegisteredUser() &&
                         resource.data.recipientUserIds.hasAny([request.auth.uid]);
        allow create: if isValidId(tournamentId) &&
                      isValidId(notificationId) &&
                      tournamentExists(tournamentId) &&
                      (isOwner(tournamentId) || isTournamentMember(tournamentId)) &&
                      isValidScoreNotification(incoming());
      }
    }

    // User History Collection
    match /users/{userId} {
      allow read: if isRegisteredUser() && request.auth.uid == userId;
      
      match /tournaments/{tournamentId} {
        allow read: if isRegisteredUser() && request.auth.uid == userId;
        allow write: if isRegisteredUser() && request.auth.uid == userId;
      }
    }

    // Global logins for notifications
    match /logins/{loginId} {
      allow get, list: if isAdmin();
      allow create: if isRegisteredUser() && 
                    incoming().uid == request.auth.uid &&
                    incoming().displayName is string;
    }

    // Membership & Invites System
    match /inviteCodes/{codeId} {
      allow read: if isRegisteredUser(); // Users check validity
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        isValidId(codeId) &&
        isRegisteredUser() &&
        incoming().code == existing().code &&
        incoming().maxUses == existing().maxUses &&
        incoming().createdAt == existing().createdAt &&
        incoming().currentUses == existing().currentUses + 1 &&
        incoming().currentUses <= existing().maxUses &&
        incoming().claimedBy.size() == existing().claimedBy.size() + 1 &&
        !existing().claimedBy.hasAny([request.auth.uid]) &&
        incoming().claimedBy.hasAll(existing().claimedBy) &&
        incoming().claimedBy.hasAll([request.auth.uid])
      );
    }

    match /memberships/{userId} {
      allow read: if isAdmin() || (isRegisteredUser() && request.auth.uid == userId);
      allow create: if isValidId(userId) &&
                    isRegisteredUser() &&
                    request.auth.uid == userId && 
                    incoming().keys().hasAll(['status', 'joinedAt']) &&
                    incoming().keys().hasOnly(['email', 'displayName', 'inviteCodeId', 'status', 'joinedAt']) &&
                    (!incoming().keys().hasAny(['email']) || incoming().email is string) &&
                    (!incoming().keys().hasAny(['displayName']) || incoming().displayName is string) &&
                    (!incoming().keys().hasAny(['inviteCodeId']) || incoming().inviteCodeId is string) &&
                    incoming().status == 'active';
      allow update: if isAdmin(); 
    }
  }
}
