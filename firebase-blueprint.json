{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "A pickleball round robin tournament",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["setup", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "code", "ownerId", "status", "createdAt"]
    },
    "Player": {
      "title": "Player",
      "description": "A player in a tournament",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "points": { "type": "number" },
        "gamesPlayed": { "type": "number" },
        "wins": { "type": "number" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "points", "gamesPlayed", "wins", "addedAt"]
    },
    "Match": {
      "title": "Match",
      "description": "A doubles match in a tournament round",
      "type": "object",
      "properties": {
        "round": { "type": "number" },
        "team1": { "type": "array", "items": { "type": "string" } },
        "team2": { "type": "array", "items": { "type": "string" } },
        "score1": { "type": "number" },
        "score2": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["round", "team1", "team2", "score1", "score2", "status", "updatedAt"]
    },
    "Login": {
      "title": "Login",
      "description": "A user login event for global notifications",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "timestamp"]
    },
    "InviteCode": {
      "title": "InviteCode",
      "description": "A multi-use invite code generated by admin",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "maxUses": { "type": "number" },
        "currentUses": { "type": "number" },
        "claimedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "maxUses", "currentUses", "claimedBy", "createdAt"]
    },
    "Membership": {
      "title": "Membership",
      "description": "Individual user membership record",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "inviteCodeId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "deactivated"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "displayName", "inviteCodeId", "status", "joinedAt"]
    }
  },
  "firestore": {
    "/inviteCodes/{codeId}": {
      "schema": "InviteCode",
      "description": "Admin generated invite codes"
    },
    "/memberships/{userId}": {
      "schema": "Membership",
      "description": "User membership statuses"
    },
    "/logins/{loginId}": {
      "schema": "Login",
      "description": "Global login events"
    },
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Root tournament document"
    },
    "/tournaments/{tournamentId}/players/{playerId}": {
      "schema": "Player",
      "description": "Players in the tournament"
    },
    "/tournaments/{tournamentId}/matches/{matchId}": {
      "schema": "Match",
      "description": "Matches scheduled for the tournament"
    }
  }
}
